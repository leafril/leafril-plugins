{
  "description": "Post-commit hook that triggers progress.md creation/update via the progress skill",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-commit.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
